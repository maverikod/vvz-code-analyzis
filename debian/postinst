#!/bin/bash
# debian/postinst — casuser, directories, venv, Docker postgres, DB init, systemd.

set -e

CASMGR_USER="casuser"
CASMGR_GROUP="casgrp"
INSTALL_DIR="/usr/lib/casmgr-server"
CONFIG_DIR="/etc/casmgr"
DATA_DIR="/var/casmgr"
LOG_DIR="/var/log/casmgr"
SECRETS="${DATA_DIR}/secrets"
CONFIG="${CONFIG_DIR}/config.json"
BIN="/usr/lib/casmgr/bin"

create_user() {
    if ! getent group "$CASMGR_GROUP" >/dev/null; then
        addgroup --system "$CASMGR_GROUP"
    fi
    if ! id "$CASMGR_USER" >/dev/null 2>&1; then
        adduser --system --ingroup "$CASMGR_GROUP" --no-create-home --shell /usr/sbin/nologin "$CASMGR_USER"
    fi
}

create_layout() {
    install -d -m 0750 -o root -g "$CASMGR_GROUP" "$CONFIG_DIR" "${CONFIG_DIR}/postgres" "${CONFIG_DIR}/mtls"
    install -d -m 0750 -o "$CASMGR_USER" -g "$CASMGR_GROUP" \
        "$DATA_DIR" "$LOG_DIR" \
        "${DATA_DIR}/postgres/data" "${DATA_DIR}/postgres/cache" \
        "${LOG_DIR}/postgres" "${DATA_DIR}/versions" "$SECRETS"
    if [[ ! -f "$CONFIG" && -f /usr/share/doc/casmgr-server/config.json.template ]]; then
        cp /usr/share/doc/casmgr-server/config.json.template "$CONFIG"
        chown root:"$CASMGR_GROUP" "$CONFIG"
        chmod 0640 "$CONFIG"
    fi
    if [[ ! -f "${SECRETS}/.env" ]]; then
        if [[ -f /usr/share/doc/casmgr-server/secrets.env.template ]]; then
            cp /usr/share/doc/casmgr-server/secrets.env.template "${SECRETS}/.env"
        fi
        if grep -q CHANGE_ME "${SECRETS}/.env" 2>/dev/null; then
            super_pw="$(openssl rand -base64 24 | tr -d '/+=' | head -c 32)"
            app_pw="$(openssl rand -base64 24 | tr -d '/+=' | head -c 32)"
            sed -i "s/CHANGE_ME_SUPER/${super_pw}/" "${SECRETS}/.env"
            sed -i "s/CHANGE_ME_APP/${app_pw}/" "${SECRETS}/.env"
            echo "Generated PostgreSQL passwords in ${SECRETS}/.env"
        fi
        chown "$CASMGR_USER:$CASMGR_GROUP" "${SECRETS}/.env"
        chmod 0640 "${SECRETS}/.env"
    fi
    chown -R 999:999 "${DATA_DIR}/postgres/data" "${DATA_DIR}/postgres/cache" 2>/dev/null || true
}

install_venv() {
    if [[ ! -d "${INSTALL_DIR}/.venv" ]]; then
        python3 -m venv "${INSTALL_DIR}/.venv"
        "${INSTALL_DIR}/.venv/bin/pip" install --upgrade pip setuptools wheel
    fi
    if [[ -f "${INSTALL_DIR}/pyproject.toml" ]]; then
        "${INSTALL_DIR}/.venv/bin/pip" install "${INSTALL_DIR}"
    else
        echo "ERROR: ${INSTALL_DIR}/pyproject.toml missing" >&2
        exit 1
    fi
    chown -R "$CASMGR_USER:$CASMGR_GROUP" "${INSTALL_DIR}/.venv"
}

setup_postgres() {
    if ! command -v docker >/dev/null 2>&1; then
        echo "WARNING: docker not installed; skip PostgreSQL container setup." >&2
        return 0
    fi
    "${BIN}/casmgr-postgres-container" pull
    "${BIN}/casmgr-postgres-container" recreate
    "${BIN}/casmgr-pg-init" || echo "WARNING: casmgr-pg-init failed; configure secrets and re-run." >&2
}

config_ready_for_server() {
    [[ -f "$CONFIG" ]] || return 1
    if grep -qE 'CHANGE_ME|MCP_PROXY_HOST' "$CONFIG" 2>/dev/null; then
        return 1
    fi
    local cert
    for cert in server.crt server.key ca.crt client.crt client.key; do
        [[ -f "${CONFIG_DIR}/mtls/${cert}" ]] || return 1
    done
    return 0
}

migrate_legacy_service() {
    if systemctl list-unit-files code-analysis-server.service >/dev/null 2>&1; then
        systemctl disable code-analysis-server.service 2>/dev/null || true
        systemctl reset-failed code-analysis-server.service 2>/dev/null || true
    fi
    if [[ -d /usr/lib/code-analysis-server && ! -e /usr/lib/casmgr-server/.migrated-from-code-analysis-server ]]; then
        echo "Note: legacy /usr/lib/code-analysis-server detected; casmgr-server uses /usr/lib/casmgr-server."
    fi
}

if [[ "$1" == "configure" ]]; then
    create_user
    create_layout
    install_venv
    migrate_legacy_service
    setup_postgres
    if [[ -f /usr/share/casmgr/docker-image ]]; then
        cp /usr/share/casmgr/docker-image "${DATA_DIR}/docker-image"
        chown root:"$CASMGR_GROUP" "${DATA_DIR}/docker-image"
        chmod 0640 "${DATA_DIR}/docker-image"
    fi
    systemctl daemon-reload
    systemctl enable casmgr-postgres.service casmgr-server.service || true
    if command -v docker >/dev/null 2>&1; then
        systemctl start casmgr-postgres.service || true
        sleep 2
        "${BIN}/casmgr-pg-init" 2>/dev/null || true
        if config_ready_for_server; then
            systemctl start casmgr-server.service || true
        else
            echo ""
            echo "casmgr-server NOT started: edit ${CONFIG}, install mTLS certs under"
            echo "  ${CONFIG_DIR}/mtls/, then run:"
            echo "  sudo systemctl start casmgr-server"
            echo ""
        fi
    fi
    echo ""
    echo "casmgr-server installed."
    echo "  Config:  ${CONFIG}"
    echo "  Secrets: ${SECRETS}/.env"
    echo "  Logs:    ${LOG_DIR}"
    echo "  Docs:    man casmgr-server   info casmgr-server"
    echo ""
fi

exit 0
