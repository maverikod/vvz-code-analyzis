code_analysis/                    # Корень репозитория
├── code_analysis/                # Исходный код проекта (пакеты, модули; индексы code_mapper при наличии)
├── docs/                         # Вся документация
│   ├── reports/                 # Анализы, пояснения, отчёты (архитектура, потоки данных)
│   ├── plans/                   # ТЗ, планы, дизайн, пошаговые планы (mutable_cst_layer, cst_concept, design)
│   ├── standards/               # Стандарты и правила (логи, драйверы, пути, коммиты, раскладка каталогов)
│   ├── commands/                # Документация по командам (по блокам: ast, cst, file_management и т.д.)
│   └── *.md, README.md, ...     # Основные гайды и индекс команд в корне docs/
├── scripts/                     # Скрипты и утилиты (не pytest): хелперы, регистрация, тест-скрипты
├── tests/                       # Только pytest-тесты
├── logs/                        # Логи сервера и приложения
├── data/                        # Данные: БД (.db, .sqlite), конфиг-данные, тестовые данные
├── mtls_certificates/           # x509-сертификаты для подключения к внешним сервисам
├── test_data/                   # Тестовые проекты; в каждой подпапке — свой проект с projectid в корне
├── .cursorrules                 # Правила организации файлов (дублируют стандарт раскладки)
└── .cursor/rules/               # Cursor-правила (filestruct, test-data, server-managing)
