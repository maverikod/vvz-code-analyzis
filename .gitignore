debian/changelog

# Debian binary outputs (dpkg-buildpackage also writes ../casmgr-server_*.deb outside this repo)
*.deb
*.changes
*.buildinfo
*.dsc

# Docker local tags / export (not the Dockerfile tree under docker/)
docker/*.tar
docker/*.tar.gz

# Cursor IDE — local debug logs only (rules/agents stay tracked)
.cursor/debug*.log

# PyInstaller
#  Usually these files are written by a python script from a template
#  before PyInstaller builds the exe, so as to inject date/other infos into it.
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

