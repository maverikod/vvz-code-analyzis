# Copy to .env and set the real password (do not commit .env).
# Used by code_analysis.database.driver (postgres) and migration scripts.
CODE_ANALYSIS_POSTGRES_PASSWORD=

# Optional: superuser password for scripts/setup_postgres_code_analysis_db.sh (psql -U postgres).
# If unset, the script tries POSTGRES_PASSWORD or PGPASSWORD after load_dotenv_near_config.
# POSTGRES_SUPERUSER_PASSWORD=
