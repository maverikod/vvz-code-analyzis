#!/bin/bash
# Rotate PostgreSQL superuser password from secrets (.env) into the running cluster.
#
# Author: Vasiliy Zdanovskiy
# email: vasilyvz@gmail.com

set -euo pipefail

_script="${BASH_SOURCE[0]}"
if command -v readlink >/dev/null 2>&1; then
    _script="$(readlink -f "$_script" 2>/dev/null || readlink "$_script" 2>/dev/null || echo "$_script")"
fi
SCRIPT_DIR="$(cd "$(dirname "$_script")" && pwd)"
# shellcheck source=casmgr-pg-common.sh
source "${SCRIPT_DIR}/casmgr-pg-common.sh"

usage() {
    cat <<EOF
Usage: $(basename "$0") [--superuser-only]

Apply PostgreSQL passwords from ${CASMGR_SECRETS}/.env to the running cluster:
  POSTGRES_SUPERUSER_PASSWORD      → superuser (postgres)
  CODE_ANALYSIS_POSTGRES_PASSWORD  → application role (unless --superuser-only)

When rotating the superuser password, set POSTGRES_SUPERUSER_CONNECT_PASSWORD to the
current cluster password for this run (see secrets.env.template).

Requires casmgr-postgres to be running. Run as root or ${CASMGR_USER}.

EOF
}

_resolve_setup_py() {
    local repo_root
    if [[ -f "/usr/share/casmgr-server/scripts/postgres_setup_from_env_config.py" ]]; then
        echo "/usr/share/casmgr-server/scripts/postgres_setup_from_env_config.py"
        return 0
    fi
    repo_root="$(cd "${SCRIPT_DIR}/../../.." && pwd)"
    echo "${repo_root}/scripts/postgres_setup_from_env_config.py"
}

main() {
    casmgr_require_root_or_casuser
    local superuser_only=0
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --superuser-only) superuser_only=1 ;;
            -h|--help) usage; exit 0 ;;
            *) echo "Unknown option: $1" >&2; usage >&2; exit 1 ;;
        esac
        shift
    done
    if [[ ! -f "$CASMGR_CONFIG" ]]; then
        echo "ERROR: missing ${CASMGR_CONFIG}" >&2
        exit 1
    fi
    if [[ ! -f "${CASMGR_SECRETS}/.env" ]]; then
        echo "ERROR: missing ${CASMGR_SECRETS}/.env" >&2
        exit 1
    fi
    casmgr_load_secrets_env
    casmgr_wait_for_postgres
    local py setup_py
    py="$(casmgr_python_for_admin)"
    setup_py="$(_resolve_setup_py)"
    export CASMGR_CONFIG
    if [[ ! -f "$setup_py" ]]; then
        echo "ERROR: postgres_setup_from_env_config.py not found" >&2
        exit 1
    fi
    "$py" "$setup_py" set-superuser-password --config "$CASMGR_CONFIG"
    if (( superuser_only == 0 )); then
        "$py" "$setup_py" ensure-app-db --config "$CASMGR_CONFIG"
        echo "OK: superuser and application passwords applied from ${CASMGR_SECRETS}/.env"
    else
        echo "OK: superuser password applied from ${CASMGR_SECRETS}/.env"
    fi
}

main "$@"
