            "INSERT OR REPLACE INTO classes (file_id, name, line, end_line, cst_node_id, docstring, bases) "
            "VALUES (?, ?, ?, ?, ?, ?, ?)",
            (file_id, name, line, end_line, cst_node_id, docstring, bases_json),
        )
        return result.get("lastrowid", 0) or 0

