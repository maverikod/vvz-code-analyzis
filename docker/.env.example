# Example environment for testing docker/docker-compose.allinone.yml locally
# (outside the packaged install). Mirrors /var/casmgr/secrets/.env; adjust
# paths in docker-compose.allinone.yml (or copy it and edit the bind mounts)
# to point at a local directory tree before using this file directly.
#
# Author: Vasiliy Zdanovskiy
# email: vasilyvz@gmail.com

POSTGRES_SUPERUSER_PASSWORD=CHANGE_ME_SUPER
CODE_ANALYSIS_POSTGRES_PASSWORD=CHANGE_ME_APP
CODE_ANALYSIS_GITHUB_TOKEN=
POSTGRES_DB=code_analysis

# Pins the image tag (vasilyvz/casmgr:<version>). Docker Compose auto-loads a
# ".env" file from its working directory (the installed casmgr.service sets
# WorkingDirectory=/etc/casmgr, where the packaged .env lives); when running
# this compose file directly from a repo checkout, keep this file named
# ".env" in the same directory you run `docker compose` from.
CASMGR_VERSION=latest
