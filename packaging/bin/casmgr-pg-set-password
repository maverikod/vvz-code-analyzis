#!/bin/bash
# Rotate PostgreSQL passwords inside the running casmgr container.
#
# Thin `docker exec` wrapper: applies POSTGRES_SUPERUSER_PASSWORD and
# CODE_ANALYSIS_POSTGRES_PASSWORD from /var/casmgr/secrets/.env to the live
# PostgreSQL cluster by re-running postgres_setup_from_env_config.py inside
# the "casmgr" container (baked into the image at /opt/casmgr/scripts/).
#
# Author: Vasiliy Zdanovskiy
# email: vasilyvz@gmail.com

set -euo pipefail

CASMGR_CONTAINER="${CASMGR_CONTAINER:-casmgr}"
CASMGR_CONFIG="${CASMGR_CONFIG:-/etc/casmgr/config.json}"
CASMGR_SECRETS="${CASMGR_SECRETS:-/var/casmgr/secrets}"
CASMGR_VENV_PYTHON="${CASMGR_VENV_PYTHON:-/opt/casmgr/venv/bin/python}"
SETUP_PY="/opt/casmgr/scripts/postgres_setup_from_env_config.py"

usage() {
    cat <<EOF
Usage: $(basename "$0") [--superuser-only]

Apply PostgreSQL passwords from ${CASMGR_SECRETS}/.env to the running
"${CASMGR_CONTAINER}" container's PostgreSQL cluster:
  POSTGRES_SUPERUSER_PASSWORD      → superuser (postgres)
  CODE_ANALYSIS_POSTGRES_PASSWORD  → application role (unless --superuser-only)

When rotating the superuser password, set POSTGRES_SUPERUSER_CONNECT_PASSWORD
to the current cluster password for this run (see secrets.env.template).

Requires the "${CASMGR_CONTAINER}" container to be running. Run as root.

EOF
}

main() {
    local superuser_only=0
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --superuser-only) superuser_only=1 ;;
            -h|--help) usage; exit 0 ;;
            *) echo "Unknown option: $1" >&2; usage >&2; exit 1 ;;
        esac
        shift
    done

    if [[ "$(id -u)" -ne 0 ]]; then
        echo "ERROR: this command must be run as root" >&2
        exit 1
    fi
    if ! command -v docker >/dev/null 2>&1; then
        echo "ERROR: docker not found" >&2
        exit 1
    fi
    if [[ "$(docker inspect -f '{{.State.Running}}' "$CASMGR_CONTAINER" 2>/dev/null)" != "true" ]]; then
        echo "ERROR: ${CASMGR_CONTAINER} container is not running (start it: sudo systemctl start casmgr.service)" >&2
        exit 1
    fi
    if [[ ! -f "${CASMGR_SECRETS}/.env" ]]; then
        echo "ERROR: missing ${CASMGR_SECRETS}/.env" >&2
        exit 1
    fi

    set -a
    # shellcheck disable=SC1091
    source "${CASMGR_SECRETS}/.env"
    set +a

    docker exec \
        -e POSTGRES_SUPERUSER_PASSWORD \
        -e POSTGRES_SUPERUSER_CONNECT_PASSWORD \
        -e CODE_ANALYSIS_POSTGRES_PASSWORD \
        -e POSTGRES_DB \
        "$CASMGR_CONTAINER" "$CASMGR_VENV_PYTHON" "$SETUP_PY" \
        set-superuser-password --config "$CASMGR_CONFIG"

    if (( superuser_only == 0 )); then
        docker exec \
            -e POSTGRES_SUPERUSER_PASSWORD \
            -e CODE_ANALYSIS_POSTGRES_PASSWORD \
            -e POSTGRES_DB \
            "$CASMGR_CONTAINER" "$CASMGR_VENV_PYTHON" "$SETUP_PY" \
            ensure-app-db --config "$CASMGR_CONFIG"
        echo "OK: superuser and application passwords applied from ${CASMGR_SECRETS}/.env"
    else
        echo "OK: superuser password applied from ${CASMGR_SECRETS}/.env"
    fi
}

main "$@"
