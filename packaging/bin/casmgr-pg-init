#!/bin/bash
# Initialize PostgreSQL application role/database after the container is running.
#
# Author: Vasiliy Zdanovskiy
# email: vasilyvz@gmail.com

set -euo pipefail

_script="${BASH_SOURCE[0]}"
if command -v readlink >/dev/null 2>&1; then
    _script="$(readlink -f "$_script" 2>/dev/null || readlink "$_script" 2>/dev/null || echo "$_script")"
fi
SCRIPT_DIR="$(cd "$(dirname "$_script")" && pwd)"
# shellcheck source=casmgr-pg-common.sh
source "${SCRIPT_DIR}/casmgr-pg-common.sh"

usage() {
    cat <<EOF
Usage: $(basename "$0") [--fix-existing-db-owner]

Ensures superuser password, application role, and database from ${CASMGR_CONFIG}.
Requires a running casmgr-postgres container and secrets in ${CASMGR_SECRETS}/.env.

EOF
}

main() {
    casmgr_require_root_or_casuser
    local fix_owner=()
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --fix-existing-db-owner) fix_owner=(--fix-existing-db-owner) ;;
            -h|--help) usage; exit 0 ;;
            *) echo "Unknown option: $1" >&2; exit 1 ;;
        esac
        shift
    done
    if [[ ! -f "$CASMGR_CONFIG" ]]; then
        echo "ERROR: missing ${CASMGR_CONFIG}" >&2
        exit 1
    fi
    casmgr_load_secrets_env
    casmgr_wait_for_postgres
    local py repo_root setup_py
    py="$(casmgr_python_for_admin)"
    export CASMGR_CONFIG
    if [[ -f "/usr/share/casmgr-server/scripts/postgres_setup_from_env_config.py" ]]; then
        setup_py="/usr/share/casmgr-server/scripts/postgres_setup_from_env_config.py"
    else
        repo_root="$(cd "${SCRIPT_DIR}/../../.." && pwd)"
        setup_py="${repo_root}/scripts/postgres_setup_from_env_config.py"
    fi
    if [[ ! -f "$setup_py" ]]; then
        echo "ERROR: postgres_setup_from_env_config.py not found" >&2
        exit 1
    fi
    "$py" "$setup_py" set-superuser-password --config "$CASMGR_CONFIG"
    "$py" "$setup_py" ensure-app-db --config "$CASMGR_CONFIG" "${fix_owner[@]}"
    echo "OK: PostgreSQL application database initialized."
}

main "$@"
